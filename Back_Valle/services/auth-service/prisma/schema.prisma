generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth"]
}

model Role {
  id          String     @id @default(uuid())
  key         String     @unique
  name        String
  description String?
  users       UserAuth[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@schema("auth")
}

model UserAuth {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  roleId        String
  isActive      Boolean        @default(true)
  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@schema("auth")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  user      UserAuth @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@schema("auth")
}
